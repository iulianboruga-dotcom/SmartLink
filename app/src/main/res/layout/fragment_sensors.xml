<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Title + lead status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Monitorizare Senzori"
                android:textColor="#00FF00"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSensLeadStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Electrozi conectati"
                android:textColor="#00CC00"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Alert banner -->
        <TextView
            android:id="@+id/tvAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:background="#330000"
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- No-data overlay -->
        <TextView
            android:id="@+id/tvNoData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:background="#111111"
            android:text="Conecteaza-te la dispozitiv pentru a vedea datele senzorilor."
            android:textColor="#666666"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="visible" />

        <!-- Row 1: Temperature + Humidity cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Temperature card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:strokeColor="#1A1A1A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TEMPERATURA"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:text="🌡"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTemp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#00FF00"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:paddingTop="4dp"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/tvTempLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fara date"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1A1A1A"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/tvTempMinMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="↓ --   ↑ --"
                        android:textColor="#555555"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Humidity card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:strokeColor="#1A1A1A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="UMIDITATE"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:text="💧"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHum"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#4FC3F7"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:paddingTop="4dp"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/tvHumLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fara date"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1A1A1A"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/tvHumMinMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="↓ --   ↑ --"
                        android:textColor="#555555"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Row 2: Pulse card (full width) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- Left: label + BPM + min/max -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PULS"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/tvBpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- BPM"
                        android:textColor="#00FF00"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/tvBpmZone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fara date"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1A1A1A"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/tvBpmMinMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="↓ --   ↑ --"
                        android:textColor="#555555"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Right: large heart icon -->
                <TextView
                    android:id="@+id/tvBpmHeart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="♥"
                    android:textColor="#888888"
                    android:textSize="64sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 3: ECG signal range card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D0D0D"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SEMNAL ECG"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tvSensEcgMinMax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Semnal ECG (ADC 12-bit)   ↓ --   ↑ --"
                    android:textColor="#444444"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ========== PROFIL / LOGIN ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFIL"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp" />

        <!-- Login form (visible when logged out) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/loginCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Autentificare"
                    android:textColor="#CCCCCC"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingBottom="12dp" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Utilizator"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:background="#1A1A1A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Parola"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:background="#1A1A1A"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Intra / Creeaza cont"
                    android:backgroundTint="#1B5E20"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prima autentificare cu un utilizator nou creeaza contul automat."
                    android:textColor="#444444"
                    android:textSize="10sp"
                    android:paddingTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Profile card (visible when logged in) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#00FF00"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Avatar circle (initials) -->
                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_green"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Conectat ca"
                        android:textColor="#666666"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvLoggedInAs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="utilizator"
                        android:textColor="#00FF00"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iesi"
                    android:backgroundTint="#3A0000"
                    android:textColor="#FF4444"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== SESIUNE ACTIVA ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SESIUNE ACTIVA"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Duration counter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Durata"
                        android:textColor="#666666"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvSessionDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--:--"
                        android:textColor="#00FF00"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A" android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvStatsPackets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pachete: 0   |   Valori totale: 0"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tvStatsEcg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ECG (ADC)    min --    max --"
                    android:textColor="#4FC3F7"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvStatsTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Temperatura   min --    max --"
                    android:textColor="#FFCC80"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvStatsHum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Umiditate     min --    max --"
                    android:textColor="#80DEEA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvStatsBpm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Puls          min --    max --"
                    android:textColor="#EF9A9A"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/btnResetSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reseteaza Sesiunea"
                    android:backgroundTint="#1A1A00"
                    android:textColor="#FFFF00"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== PRAGURI ALERTE ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PRAGURI ALERTE"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Temperature thresholds -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Temperatura (°C)"
                    android:textColor="#FFCC80"
                    android:textSize="12sp"
                    android:paddingBottom="6dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etTempHigh" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textColor="#FF8888" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etTempLow" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textColor="#88CCFF" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Humidity thresholds -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Umiditate (%)"
                    android:textColor="#80DEEA"
                    android:textSize="12sp"
                    android:paddingBottom="6dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etHumHigh" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textColor="#FF8888" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etHumLow" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textColor="#88CCFF" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- BPM thresholds -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Puls (BPM)"
                    android:textColor="#EF9A9A"
                    android:textSize="12sp"
                    android:paddingBottom="6dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etBpmHigh" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:textColor="#FF8888" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min" android:textColor="#666666" android:textSize="11sp" />
                        <EditText android:id="@+id/etBpmLow" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:textColor="#88CCFF" android:background="#1A1A1A" android:padding="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== DISPOZITIV BLE ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DISPOZITIV BLE"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nume dispozitiv BLE (pentru scan)"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:paddingBottom="6dp" />

                <EditText
                    android:id="@+id/etDeviceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="#00FF00"
                    android:background="#1A1A1A"
                    android:padding="10dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Salveaza Setarile"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
